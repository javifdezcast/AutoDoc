/**
 * Pure mathematical helpers shared between the analytics and pricing modules. The exported constants are frozen and safe to use as reference values in arithmetic operations.
 *
 * @remarks
 * Module-level variables:
 * - `EPSILON` (`number`): Tolerance used for floating-point equality checks.
 * - `TWO_PI` (`number`): Convenience constant equal to `2 * Math.PI`.
 *
 * @packageDocumentation
 */

// File: src/math-utils.ts

export const EPSILON: number = 1e-9;
export const TWO_PI: number = 2 * Math.PI;

export function approxEqual(a: number, b: number): boolean {
  return Math.abs(a - b) < EPSILON;
}

export function normaliseAngle(radians: number): number {
  const mod = radians % TWO_PI;
  return mod < 0 ? mod + TWO_PI : mod;
}