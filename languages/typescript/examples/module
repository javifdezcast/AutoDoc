/**
 * Centralised runtime configuration loaded from environment variables. Values are read once at import time and frozen; consumers should import the named exports rather than mutate them.
 *
 * @remarks
 * Module-level variables:
 * - `API_BASE_URL` (`string`): Root URL of the upstream API service.
 * - `REQUEST_TIMEOUT_MS` (`number`): Default timeout applied to outbound HTTP calls, in milliseconds.
 * - `FEATURE_FLAGS` (`ReadonlyMap<string, boolean>`): Map of feature-flag names to their resolved enabled/disabled state.
 *
 * @packageDocumentation
 */

// File: src/config.ts
//
// Module-level documentation generated for the whole file (program node).

export const API_BASE_URL: string =
  process.env.API_BASE_URL ?? 'https://api.example.com';

export const REQUEST_TIMEOUT_MS: number =
  Number(process.env.REQUEST_TIMEOUT_MS ?? 5000);

export const FEATURE_FLAGS: ReadonlyMap<string, boolean> = new Map(
  Object.entries(JSON.parse(process.env.FEATURE_FLAGS ?? '{}'))
    .map(([k, v]) => [k, Boolean(v)] as const),
);

