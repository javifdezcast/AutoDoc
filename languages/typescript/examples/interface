/**
 * Configuration object describing how a client should retry transient failures. Implementations of this contract are consumed by network and database adapters across the codebase.
 *
 * @remarks
 * Properties:
 * - `maxAttempts` (`number`): Maximum number of attempts, including the initial call.
 * - `initialDelayMs` (`number`): Delay before the first retry, in milliseconds.
 * - `backoff` (`'fixed' | 'linear' | 'exponential'`): Strategy used to scale the delay between successive retries.
 * - `retryOn` (`(error: unknown) => boolean`): Predicate returning `true` when an error is considered transient.
 */
interface RetryPolicy {
  maxAttempts: number;
  initialDelayMs: number;
  backoff: 'fixed' | 'linear' | 'exponential';
  retryOn: (error: unknown) => boolean;
}