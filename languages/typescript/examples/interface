/**
 * Envelope returned by list endpoints that paginate results. `items` holds the current page; `nextCursor` is `null` when the final page has been reached.
 *
 * @remarks
 * Properties:
 * - `items` (`T[]`): The records on the current page.
 * - `nextCursor` (`string | null`): Opaque cursor for the next page, or `null` if no more pages exist.
 * - `total` (`number`): Total number of records across all pages.
 */
interface PaginatedResponse<T> {
  items: T[];
  nextCursor: string | null;
  total: number;
}

