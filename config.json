{
  "project_name": "auto-doc",
  "llm": {
    "provider": "ollama",
    "base_url": "http://127.0.0.1:11434",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.3,
    "num_parallel": 1,
    "context_length": 4096,
    "max_loaded_models": 1,
    "keep_alive": "-1"
  },
  "docker": {
    "image": "ollama/ollama:latest"
  },
  "language": "python",
  "root_dir": "/home/javi/Projects/scc-my-time",
  "scope": "all",
  "mode": "clone",
  "ignore": [
    "/venv/",
    "/.venv/",
    "/env/",
    "/.env",
    "/virtualenv/",
    "/site-packages/",
    "/.git/",
    "/.hg/",
    "/.svn/",
    "/__pycache__/",
    "/.pytest_cache/",
    "/.mypy_cache/",
    "/.ruff_cache/",
    "/.pytype/",
    "/.pyre/",
    "/.tox/",
    "/.nox/",
    "/build/",
    "/dist/",
    "/.eggs/",
    ".egg-info",
    "/.idea/",
    "/.vscode/",
    "/htmlcov/",
    "/.coverage",
    "/.ipynb_checkpoints/",
    "/_build/",
    "/.DS_Store",
    "/.cache/"
  ],
  "elements_to_document": [
    "class_definition",
    "module",
    "function_definition"
  ],
  "python": {
    "elements_to_document": [
      "program",
      "function_declaration",
      "method_definition",
      "class_declaration",
      "interface_declaration"
    ],
    "ignore": [
      "/node_modules/",
      "/.git/",
      "/.hg/",
      "/.svn/",
      "/dist/",
      "/tmp/",
      "/out-tsc/",
      "/bazel-out/",
      "/.angular/",
      "/coverage/",
      "/e2e/",
      "/.nyc_output/",
      "/.idea/",
      "/.vscode/",
      "/.cache/",
      "/.sass-cache/",
      "/connect.lock/",
      "/libpeerconnection.log/",
      "/.DS_Store",
      "/Thumbs.db",
      ".min.js",
      ".min.css",
      "/.husky/",
      "/.github/",
      "api"
    ]
  }
}
